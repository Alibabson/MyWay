<Application x:Class="MyWay.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:MyWay.Converters"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters -->
            <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
            <converters:BoolToInverseVisibilityConverter x:Key="BoolToInvVis"/>
            <converters:DifficultyToColorConverter x:Key="DiffToColor"/>
            <converters:CompletedToStrikethroughConverter x:Key="CompletedToStrike"/>
            <converters:CompletedToOpacityConverter x:Key="CompletedToOpacity"/>
            <converters:OverdueToColorConverter x:Key="OverdueToColor"/>
            <converters:StreakToColorConverter x:Key="StreakToColor"/>
            <converters:NullToVisibilityConverter x:Key="NullToVis"/>
            <converters:MoodToColorConverter x:Key="MoodToColor"/>
            <converters:IsCompletedTodayToColorConverter x:Key="CompletedTodayToColor"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
