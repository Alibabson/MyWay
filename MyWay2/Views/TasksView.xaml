<UserControl x:Class="MyWay.Views.TasksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Style x:Key="SegmentedListBox" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ItemsPanel">
                <Setter.Value>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SegmentedListBoxItem" TargetType="ListBoxItem">
            <Setter Property="Background" Value="#12121F"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="0,0,4,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ChipBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ChipBorder" Property="Background" Value="{StaticResource AccentPurpleBrush}"/>
                                <Setter TargetName="ChipBorder" Property="BorderBrush" Value="{StaticResource AccentPurpleBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20,10,20,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="✅ Zadania" Style="{StaticResource SectionHeader}" FontSize="18" Margin="0"/>
            <Border Background="{StaticResource AccentPurpleBrush}" CornerRadius="8"
                    Padding="4,0" Margin="8,0,0,8" VerticalAlignment="Center">
                <TextBlock Foreground="White" FontSize="9" FontWeight="Bold" Text="{Binding Tasks.Count, Mode=OneWay}"/>
            </Border>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,10" Padding="10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Szukaj:" Style="{StaticResource Label}" FontSize="11" Margin="0,0,4,0"/>
                    <TextBox Style="{StaticResource DarkTextBox}" Width="100" Height="24" FontSize="11"
                             Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,15,0"/>

                    <TextBlock Text="Status:" Style="{StaticResource Label}" FontSize="11" Margin="0,0,4,0"/>
                    <ComboBox Style="{StaticResource DarkComboBox}" Width="100" Height="24" FontSize="11"
                              SelectedValue="{Binding FilterStatus}" SelectedValuePath="Content" Margin="0,0,15,0">
                        <ComboBoxItem Content="Wszystkie" IsSelected="True"/>
                        <ComboBoxItem Content="Aktywne"/>
                        <ComboBoxItem Content="Zaległe"/>
                        <ComboBoxItem Content="Ukończone"/>
                    </ComboBox>

                    <TextBlock Text="Sortuj:" Style="{StaticResource Label}" FontSize="11" Margin="0,0,4,0"/>
                    <ComboBox Style="{StaticResource DarkComboBox}" Width="100" Height="24" FontSize="11"
                              SelectedValue="{Binding SortBy}" SelectedValuePath="Content">
                        <ComboBoxItem Content="Data" IsSelected="True"/>
                        <ComboBoxItem Content="Trudność"/>
                        <ComboBoxItem Content="Nazwa"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Text="{Binding TodayCompleted}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource AccentGreenBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="dziś" FontSize="8" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Text="{Binding OverdueCount}" FontSize="14" FontWeight="Bold" Foreground="#FF7043" HorizontalAlignment="Center"/>
                        <TextBlock Text="zaległe" FontSize="8" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="{Binding TotalPoints}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource AccentPurpleBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="pkt" FontSize="8" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
                <ListView ItemsSource="{Binding TasksView}" Background="Transparent" BorderThickness="0" Padding="5">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Margin" Value="0,1"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <ContentPresenter />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource BgCardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="8,5">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsCompleted, Mode=OneWay}" 
                                              Command="{Binding DataContext.ToggleCompleteCommand, RelativeSource={RelativeSource AncestorType=ListView}}" 
                                              CommandParameter="{Binding}" VerticalAlignment="Center" Margin="0,0,8,0"/>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Title}" FontSize="12" Foreground="{Binding IsOverdue, Converter={StaticResource OverdueToColor}}" TextDecorations="{Binding IsCompleted, Converter={StaticResource CompletedToStrike}}"/>
                                            <Border Background="{Binding Difficulty, Converter={StaticResource DiffToColor}}" CornerRadius="3" Padding="3,0" Margin="5,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DifficultyIcon}" FontSize="8"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding DueDate, StringFormat={}{0:dd.MM.yyyy}}" FontSize="9" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                                        <Button Content="🎯" Style="{StaticResource GhostButton}" Padding="4,2" FontSize="11" Command="{Binding DataContext.StartFocusCommand, RelativeSource={RelativeSource AncestorType=ListView}}" CommandParameter="{Binding}"/>
                                        <Button Content="🗑" Style="{StaticResource DangerButton}" Padding="4,2" FontSize="11" Margin="3,0,0,0" Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=ListView}}" CommandParameter="{Binding}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>

            <StackPanel Grid.Column="2">
                <Border Style="{StaticResource Card}" Margin="0,0,0,10" Padding="5">
                    <StackPanel>
                        <TextBlock Text="📅 Wybierz dzień" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="5,0,0,2"/>
                        <Viewbox MaxHeight="180">
                            <Calendar SelectedDate="{Binding SelectedDate}" Background="Transparent" BorderThickness="0"/>
                        </Viewbox>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Nowe zadanie" Style="{StaticResource SectionHeader}" FontSize="13" Margin="0,0,0,6"/>

                        <TextBox Style="{StaticResource DarkTextBox}" Height="28" 
                                 Text="{Binding NewTitle, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6"/>

                        <TextBlock Text="Trudność" Style="{StaticResource Label}" FontSize="11" Margin="0,0,0,3"/>
                        <ListBox Style="{StaticResource SegmentedListBox}" ItemContainerStyle="{StaticResource SegmentedListBoxItem}"
                                 SelectedValue="{Binding NewDifficulty}" SelectedValuePath="Tag" Margin="0,0,0,8">
                            <ListBoxItem Content="⭐ Łatwe" Tag="1" IsSelected="True"/>
                            <ListBoxItem Content="⭐⭐ Średnie" Tag="2"/>
                            <ListBoxItem Content="⭐⭐⭐ Trudne" Tag="3"/>
                        </ListBox>

                        <TextBlock Text="Termin" Style="{StaticResource Label}" FontSize="11" Margin="0,0,0,3"/>
                        <Border Background="#12121F" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="5" Padding="5,3" Margin="0,0,0,12">
                            <TextBlock Text="{Binding NewDueDate, StringFormat={}{0:dd MMMM yyyy}}" FontSize="11" Foreground="{StaticResource AccentPurpleBrush}" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </Border>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="➕ Dodaj" Style="{StaticResource BaseButton}" Command="{Binding AddTaskCommand}" Height="28" FontSize="11"/>
                            <Button Grid.Column="2" Content="✅ Zrobione" Style="{StaticResource GreenButton}" Command="{Binding AddCompletedTaskCommand}" Height="28" FontSize="11"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>