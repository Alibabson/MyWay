<UserControl x:Class="MyWay.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel Margin="24,20,24,24">
            <TextBlock Style="{StaticResource SectionHeader}" FontSize="22">
                <Run Text="🌅  Dzień dobry!  "/>
                <Run Text="{Binding TodayRecord.Date, StringFormat={}{0:dddd, dd MMMM yyyy}, Mode=OneWay}"
                     Foreground="{StaticResource TextSecondaryBrush}" FontSize="14" FontWeight="Normal"/>
            </TextBlock>

            <Border Style="{StaticResource Card}" Margin="0,0,0,16"
                    Background="#16162A" BorderBrush="#7C4DFF" BorderThickness="0,0,0,3">
                <StackPanel>
                    <TextBlock Text="💬 Cytat dnia" Style="{StaticResource Label}" Margin="0,0,0,6"/>
                    <TextBlock Text="{Binding QuoteText}" FontSize="14" FontStyle="Italic"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               TextWrapping="Wrap" LineHeight="22"/>
                </StackPanel>
            </Border>

            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="340"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="🔥 Nawyki" Style="{StaticResource SectionHeader}" FontSize="18"/>

                    <Border Style="{StaticResource Card}" Margin="0,0,0,16" Background="#16162A" Padding="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,24,0" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding CompletedToday}" FontSize="24" FontWeight="Black"
                                           Foreground="{StaticResource AccentGreenBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="ukończone dziś" FontSize="10"
                                           Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,24,0" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding TotalStreakDays}" FontSize="24" FontWeight="Black"
                                           Foreground="#FF7043" HorizontalAlignment="Center"/>
                                <TextBlock Text="suma dni streak" FontSize="10"
                                           Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding BestStreak}" FontSize="24" FontWeight="Black"
                                           Foreground="{StaticResource AccentPurpleBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="najlepszy streak" FontSize="10"
                                           Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBox Style="{StaticResource DarkTextBox}"
                                         Text="{Binding NewHabitTitle, UpdateSourceTrigger=PropertyChanged}"
                                         Width="160" Margin="0,0,8,0" VerticalContentAlignment="Center">
                                    <TextBox.InputBindings>
                                        <KeyBinding Key="Return" Command="{Binding AddHabitCommand}"/>
                                    </TextBox.InputBindings>
                                </TextBox>
                                <Button Content="➕ Dodaj" Style="{StaticResource BaseButton}"
                                        Command="{Binding AddHabitCommand}" Padding="12,6"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource Card}" Padding="0">
                        <ItemsControl ItemsSource="{Binding Habits}" Padding="12">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,4"
                                            Background="{Binding IsCompletedToday, Converter={StaticResource CompletedTodayToColor}}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1" CornerRadius="10" Padding="16,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18"
                                                    Background="{Binding IsCompletedToday, Converter={StaticResource CompletedTodayToColor}}"
                                                    BorderBrush="{Binding CurrentStreak, Converter={StaticResource StreakToColor}}"
                                                    BorderThickness="2" Margin="0,0,14,0" Cursor="Hand">
                                                <Border.InputBindings>
                                                    <MouseBinding MouseAction="LeftClick"
                                                                  Command="{Binding DataContext.ToggleHabitCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                  CommandParameter="{Binding}"/>
                                                </Border.InputBindings>
                                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="○"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsCompletedToday}" Value="True">
                                                                    <Setter Property="Text" Value="✓"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}" FontSize="15" FontWeight="Medium"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                    <TextBlock Text="{Binding StreakLabel}" FontSize="12"
                                                               Foreground="{Binding CurrentStreak, Converter={StaticResource StreakToColor}}"/>
                                                    <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="12,0,0,0">
                                                        <Run Text="Rekord: "/>
                                                        <Run Text="{Binding BestStreak, Mode=OneWay}"/>
                                                        <Run Text=" dni"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>

                                            <Button Grid.Column="2" Content="🗑" Style="{StaticResource DangerButton}"
                                                    Padding="8,6" FontSize="13" VerticalAlignment="Center"
                                                    Command="{Binding DataContext.DeleteHabitCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </StackPanel>

                <Border Grid.Column="2" Style="{StaticResource Card}" VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="😊 Twój nastrój dziś" Style="{StaticResource SectionHeader}" FontSize="14"/>
                        <TextBlock Text="{Binding TodayRecord.MoodLabel}" FontSize="28"
                                   HorizontalAlignment="Center" Margin="0,8"/>
                        <Slider Minimum="1" Maximum="5" TickFrequency="1"
                                IsSnapToTickEnabled="True" TickPlacement="BottomRight"
                                Value="{Binding TodayRecord.MoodScore}"
                                Foreground="{StaticResource AccentPurpleBrush}"
                                Margin="0,4,0,12"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="😞" FontSize="12" Margin="0,0,8,0" Opacity="0.5"/>
                            <TextBlock Text="1  2  3  4  5" FontSize="10"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Text="😄" FontSize="12" Margin="8,0,0,0" Opacity="0.5"/>
                        </StackPanel>
                        <Button Content="Zapisz nastrój" Style="{StaticResource GreenButton}"
                                Command="{Binding SaveMoodCommand}"
                                Margin="0,16,0,0" HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>