<UserControl x:Class="MYWAY.Views.PeriodSummaryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1000">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Background="#F8FAFC" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding PeriodTitle}" FontSize="28" FontWeight="Bold" Foreground="#1E293B"/>
                        <TextBlock Text="{Binding PeriodDescription}" FontSize="14" Foreground="#64748B" Margin="0,5,0,0"/>
                    </StackPanel>

                    <Button Grid.Column="1" Content="↶ Wróć do Statystyk" Style="{StaticResource SecondaryButton}"
                            VerticalAlignment="Center" Margin="0,0,10,0"
                            Command="{Binding ChangeViewCommand}" CommandParameter="2"/>
                </Grid>
            </Border>

            <!-- Content -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Tasks Summary -->
                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="5">
                    <StackPanel Margin="20">
                        <TextBlock Text="Wykonane Zadania" FontSize="20" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,15"/>

                        <ListBox ItemsSource="{Binding PeriodTasks}" BorderThickness="0" Background="Transparent"
                                 HorizontalContentAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1"
                                            CornerRadius="8" Padding="15" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="SemiBold" Foreground="#334155"/>
                                                <TextBlock Text="{Binding DueDate, StringFormat='Data: {0:dd.MM.yyyy}'}" FontSize="12" Foreground="#64748B" Margin="0,2,0,0"/>
                                            </StackPanel>

                                            <TextBlock Grid.Column="1" Text="{Binding DifficultyText}" FontSize="12" FontWeight="Bold"
                                                       Foreground="#10B981" VerticalAlignment="Center" Margin="0,0,15,0"/>

                                            <TextBlock Grid.Column="2" Text="✅" FontSize="16" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <TextBlock Text="{Binding PeriodTasks.Count, StringFormat='Razem zadań: {0}'}" FontSize="14" Foreground="#64748B"
                                   HorizontalAlignment="Center" Margin="0,15,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Extra Activities Summary -->
                <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="5">
                    <StackPanel Margin="20">
                        <TextBlock Text="Dodatkowe Aktywności" FontSize="20" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,15"/>

                        <ListBox ItemsSource="{Binding PeriodExtraActivities}" BorderThickness="0" Background="Transparent"
                                 HorizontalContentAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1"
                                            CornerRadius="8" Padding="15" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="SemiBold" Foreground="#334155"/>
                                                <TextBlock Text="{Binding Date, StringFormat='Data: {0:dd.MM.yyyy}'}" FontSize="12" Foreground="#64748B" Margin="0,2,0,0"/>
                                            </StackPanel>

                                            <TextBlock Grid.Column="1" Text="{Binding Points, StringFormat='+{0} pkt'}" FontSize="14" FontWeight="Bold"
                                                       Foreground="#8B5CF6" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <TextBlock Text="{Binding PeriodExtraActivities.Count, StringFormat='Razem aktywności: {0}'}" FontSize="14" Foreground="#64748B"
                                   HorizontalAlignment="Center" Margin="0,15,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>