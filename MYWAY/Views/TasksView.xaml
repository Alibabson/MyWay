<UserControl x:Class="MYWAY.Views.TasksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="6*"/>
            <ColumnDefinition Width="4*"/>
        </Grid.ColumnDefinitions>

        <!-- Left: To-Do List & Extra Tasks -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="3*"/>
                <RowDefinition Height="2*"/>
            </Grid.RowDefinitions>

            <!-- Regular Tasks -->
            <Border Grid.Row="0" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="{Binding SelectedDate, StringFormat='Zadania na: {0:dd.MM.yyyy}'}" FontSize="22" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,15"/>

                    <!-- Add Task Form -->
                    <Grid Grid.Row="1" Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding NewTaskTitle, UpdateSourceTrigger=PropertyChanged}" 
                                 Padding="10,8" FontSize="14" Margin="0,0,10,0" ToolTip="Tytuł zadania"/>
                        
                        <ComboBox Grid.Column="1" SelectedIndex="{Binding NewTaskDifficulty}" Width="140" Margin="0,0,10,0" VerticalContentAlignment="Center" Padding="5">
                            <ComboBoxItem Content="Wybierz Trudność..."/>
                            <ComboBoxItem Content="Łatwe (1)"/>
                            <ComboBoxItem Content="Średnie (2)"/>
                            <ComboBoxItem Content="Trudne (3)"/>
                        </ComboBox>

                        <Button Grid.Column="2" Content="Dodaj" Style="{StaticResource PrimaryButton}" 
                                Command="{Binding AddTaskCommand}"/>
                    </Grid>

                    <!-- Task List (Filtered) -->
                    <ListBox Grid.Row="2" ItemsSource="{Binding FilteredTasks}" BorderThickness="0" Background="Transparent" HorizontalContentAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#F8FAFC" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsCompleted, Mode=OneWay}" 
                                                  Command="{Binding DataContext.CompleteTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                  CommandParameter="{Binding}" VerticalAlignment="Center" Margin="0,0,15,0">
                                            <CheckBox.LayoutTransform>
                                                <ScaleTransform ScaleX="1.5" ScaleY="1.5"/>
                                            </CheckBox.LayoutTransform>
                                        </CheckBox>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="SemiBold" Foreground="#334155"
                                                       TextDecorations="{Binding IsCompleted, Converter={StaticResource BooleanToTextDecorationConverter}, FallbackValue=None}" />
                                            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                                <Border Background="#DBEAFE" CornerRadius="4" Padding="5,2" Margin="0,0,10,0">
                                                    <TextBlock Text="{Binding DifficultyText}" FontSize="12" Foreground="#1E40AF" FontWeight="SemiBold"/>
                                                </Border>
                                                <Border Background="#FEE2E2" CornerRadius="4" Padding="5,2" Visibility="{Binding IsOverdue, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Text="Zaległe" FontSize="12" Foreground="#991B1B" FontWeight="Bold"/>
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>

                                        <Button Grid.Column="2" Content="⏱ Skupienie" Background="#10B981" Foreground="White" BorderThickness="0" Padding="10,5" Margin="0,0,10,0"
                                                Command="{Binding DataContext.StartFocusTimerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" VerticalAlignment="Center"
                                                Visibility="{Binding IsCompleted, Converter={StaticResource InvertedBooleanToVisibilityConverter}}"/>
                                        
                                        <Button Grid.Column="3" Content="🗑 Usuń" Background="#EF4444" Foreground="White" BorderThickness="0" Padding="10,5"
                                                Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Dodatkowe Zadania -->
            <Border Grid.Row="1" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="Dodatkowe Zadania" FontSize="18" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,10"/>
                    
                    <StackPanel Grid.Row="1" Margin="0,0,0,10">
                        <TextBox Text="{Binding NewExtraTitle, UpdateSourceTrigger=PropertyChanged}" Padding="8" Margin="0,0,0,10" ToolTip="Opis np. Ciężki trening (Siłownia)"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Punkty:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#334155" FontWeight="SemiBold"/>
                            <TextBox Grid.Column="1" Text="{Binding NewExtraPoints, UpdateSourceTrigger=PropertyChanged}" Width="50" HorizontalAlignment="Left" Padding="5"/>
                            <Button Grid.Column="2" Content="Dodaj Aktywność" Style="{StaticResource SecondaryButton}" Command="{Binding AddExtraActivityCommand}"/>
                        </Grid>
                    </StackPanel>

                    <ListBox Grid.Row="2" ItemsSource="{Binding FilteredExtraActivities}" BorderThickness="0" Background="Transparent" HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#F3F4F6" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold" Foreground="#334155" TextWrapping="Wrap"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Points, StringFormat='+ {0} pkt'}" FontSize="14" FontWeight="Bold" Foreground="#10B981" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <!-- Right: Calendar & Navigation -->
        <Border Grid.Column="1" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Calendar -->
                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,20">
                    <TextBlock Text="Wybierz Dzień" FontSize="18" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                    <Calendar SelectedDate="{Binding SelectedDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Background="White" BorderBrush="#E2E8F0" BorderThickness="1"/>
                    
                    <TextBlock Text="{Binding TotalPoints, StringFormat='⭐ Punkty w tym dniu: {0}'}" FontSize="18" FontWeight="Bold" Foreground="#F59E0B" HorizontalAlignment="Center" Margin="0,20,0,0"/>
                </StackPanel>

                <!-- Navigation Buttons -->
                <StackPanel Grid.Row="1" VerticalAlignment="Bottom">
                    <Button Content="Pokaż Nawyki i Nastrój" Style="{StaticResource PrimaryButton}" Background="#10B981" Margin="0,0,0,10" Padding="15,15" FontSize="16"
                            Command="{Binding ChangeViewCommand}" CommandParameter="1"/>
                    <Button Content="Przejdź do Statystyk" Style="{StaticResource PrimaryButton}" Background="#3B82F6" Padding="15,15" FontSize="16"
                            Command="{Binding ChangeViewCommand}" CommandParameter="2"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
