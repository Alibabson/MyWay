<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="MYWAY.Views.TasksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000">
    <UserControl.Resources>
        <Style x:Key="ModernCalendarDayButton" TargetType="CalendarDayButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextStrong}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="MinWidth" Value="44"/>
            <Setter Property="MinHeight" Value="44"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CalendarDayButton">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                SnapsToDevicePixels="True">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" TextElement.FontSize="17"/>
                                <Ellipse x:Name="DayMarker" Width="8" Height="8" Fill="#2563EB" Visibility="Collapsed" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#E5EEFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentBlue}"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding IsToday, RelativeSource={RelativeSource Self}}" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource AccentPurple}"/>
                                <Setter TargetName="Root" Property="BorderThickness" Value="2"/>
                            </DataTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <EventSetter Event="Loaded" Handler="CalendarDayButton_Loaded"/>
        </Style>
        <Style x:Key="ModernCalendarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextStrong}"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EEF2FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5*"/>
            <ColumnDefinition Width="5*"/>
        </Grid.ColumnDefinitions>

        <!-- Left: Add Task + Extra Activity and Today's Tasks -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Combined add form -->
            <Border Grid.Row="0" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1.3*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,15">
                        <TextBlock Text="Szybkie dodawanie" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextStrong}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="Nazwa zadania" FontSize="12" Foreground="{StaticResource TextMuted}"/>
                        <TextBox Text="{Binding NewTaskTitle, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource InputTextBox}" Margin="0,6,0,0" Height="38" ToolTip="Tytuł zadania"/>

                        <TextBlock Text="Poziom trudności" FontSize="12" Foreground="{StaticResource TextMuted}" Margin="0,16,0,0"/>
                        <Border Background="{StaticResource SurfaceAlt}" BorderBrush="{StaticResource Stroke}" BorderThickness="1" CornerRadius="12" Padding="10" Margin="0,6,0,0">
                            <StackPanel>
                                <RadioButton Content="Łatwe – szybkie zadanie"
                                             GroupName="TaskDifficulty"
                                             IsChecked="{Binding NewTaskDifficulty, Mode=TwoWay, Converter={StaticResource IntToBooleanConverter}, ConverterParameter=1}" 
                                             Margin="0,0,0,8"/>
                                <RadioButton Content="Średnie – umiarkowany wysiłek"
                                             GroupName="TaskDifficulty"
                                             IsChecked="{Binding NewTaskDifficulty, Mode=TwoWay, Converter={StaticResource IntToBooleanConverter}, ConverterParameter=2}" 
                                             Margin="0,0,0,8"/>
                                <RadioButton Content="Trudne – bardziej wymagające"
                                             GroupName="TaskDifficulty"
                                             IsChecked="{Binding NewTaskDifficulty, Mode=TwoWay, Converter={StaticResource IntToBooleanConverter}, ConverterParameter=3}"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="{Binding NewTaskDifficultyDescription}"
                                   FontSize="12" Foreground="{StaticResource TextMuted}" Margin="0,10,0,0" TextWrapping="Wrap"/>
                        <Button Content="Dodaj zadanie" Style="{StaticResource PrimaryButton}"
                                Command="{Binding AddTaskCommand}" Width="140" Height="38" HorizontalAlignment="Right" Margin="0,16,0,0"/>
                    </StackPanel>

                    <Border Grid.Row="1" Grid.Column="1" Background="{StaticResource SurfaceAlt}" BorderBrush="{StaticResource Stroke}" BorderThickness="1" CornerRadius="12" Padding="16">
                        <StackPanel>
                            <TextBlock Text="Dodatkowa aktywność" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextStrong}"/>
                            <TextBox Text="{Binding NewExtraTitle, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBox}"
                                     Margin="0,0,0,10" Height="38" ToolTip="Opis aktywności"/>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Punkty:" VerticalAlignment="Center" Margin="0,0,10,0"
                                           Foreground="{StaticResource TextMuted}" FontWeight="SemiBold"/>
                                <TextBox Grid.Column="1" Text="{Binding NewExtraPoints, UpdateSourceTrigger=PropertyChanged}" Width="70"
                                         HorizontalAlignment="Left" VerticalAlignment="Center" VerticalContentAlignment="Center"
                                         Height="34" Style="{StaticResource InputTextBox}" Padding="6,4"/>
                                <Button Grid.Column="2" Content="Dodaj aktywność" Style="{StaticResource SecondaryButton}"
                                        Command="{Binding AddExtraActivityCommand}" Margin="10,0,0,0"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Today's Tasks + Activities -->
            <Border Grid.Row="1" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,15">
                        <TextBlock Text="Zadania na dziś" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextStrong}"/>
                        <TextBlock Text="Zobacz główne zadania i dodatkowe aktywności w jednym panelu. Każda pozycja jest wyraźnie oznaczona." FontSize="13" Foreground="{StaticResource TextMuted}" Margin="0,8,0,0" TextWrapping="Wrap"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="580">
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="Zadania" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextStrong}" Margin="0,0,0,8"/>
                            <ListBox ItemsSource="{Binding FilteredTasks}" BorderThickness="0" Background="Transparent"
                                     HorizontalContentAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Disabled" Margin="0,0,0,10">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource SurfaceAlt}" BorderBrush="{StaticResource Stroke}" BorderThickness="1"
                                            CornerRadius="10" Padding="15" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <CheckBox Grid.Column="0" IsChecked="{Binding IsCompleted, Mode=OneWay}"
                                                      Command="{Binding DataContext.CompleteTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      CommandParameter="{Binding}" VerticalAlignment="Center" Margin="0,0,15,0">
                                                <CheckBox.LayoutTransform>
                                                    <ScaleTransform ScaleX="1.4" ScaleY="1.4"/>
                                                </CheckBox.LayoutTransform>
                                            </CheckBox>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,6">
                                                    <Border Background="#DBEAFE" CornerRadius="4" Padding="4,2" Margin="0,0,8,0">
                                                        <TextBlock Text="Zadanie" FontSize="11" FontWeight="Bold" Foreground="#1E40AF"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding DifficultyText}" FontSize="12" Foreground="#475569" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextStrong}"
                                                           TextDecorations="{Binding IsCompleted, Converter={StaticResource BooleanToTextDecorationConverter}, FallbackValue=None}" />
                                            </StackPanel>

                                            <Button Grid.Column="2" Content="Skupienie" Style="{StaticResource PrimaryButton}"
                                                    Background="{StaticResource AccentGreen}" Margin="0,0,10,0"
                                                    Command="{Binding DataContext.StartFocusTimerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}" VerticalAlignment="Center"
                                                    Visibility="{Binding IsCompleted, Converter={StaticResource InvertedBooleanToVisibilityConverter}}"/>

                                            <Button Grid.Column="3" Content="Usuń" Style="{StaticResource PrimaryButton}"
                                                    Background="{StaticResource Danger}"
                                                    Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <TextBlock Text="Dodatkowe aktywności" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextStrong}" Margin="0,10,0,8"/>
                        <ListBox ItemsSource="{Binding FilteredExtraActivities}" BorderThickness="0" Background="Transparent"
                                 HorizontalContentAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource SurfaceAlt}" BorderBrush="{StaticResource Stroke}" BorderThickness="1"
                                            CornerRadius="10" Padding="15" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,6">
                                                    <Border Background="#D1FAE5" CornerRadius="4" Padding="4,2" Margin="0,0,8,0">
                                                        <TextBlock Text="Aktywność" FontSize="11" FontWeight="Bold" Foreground="#047857"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding Points, StringFormat='+ {0} pkt'}" FontSize="12" Foreground="#475569" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextStrong}" TextWrapping="Wrap"/>
                                            </StackPanel>

                                            <Button Grid.Column="1" Content="Usuń" Style="{StaticResource PrimaryButton}"
                                                    Background="{StaticResource Danger}"
                                                    Command="{Binding DataContext.DeleteExtraActivityCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- Right: Calendar & Navigation -->
        <Border Grid.Column="1" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,16" HorizontalAlignment="Center">
                    <TextBlock Text="Kalendarz" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextStrong}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Wybierz dzień, aby przypisać zadania do tej daty." FontSize="13" Foreground="{StaticResource TextMuted}"
                               Margin="0,8,0,0" TextWrapping="Wrap" TextAlignment="Center" Width="260"/>
                </StackPanel>

                <Border Grid.Row="1" Background="{StaticResource SurfaceAlt}" BorderBrush="{StaticResource Stroke}" BorderThickness="1"
                        CornerRadius="16" Padding="18" MinHeight="520">
                    <Calendar x:Name="TaskCalendar" SelectedDate="{Binding SelectedDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              DisplayMode="Month" FirstDayOfWeek="Monday" IsTodayHighlighted="True" Background="Transparent"
                              BorderThickness="0" FontSize="16" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                              CalendarDayButtonStyle="{StaticResource ModernCalendarDayButton}"
                              CalendarButtonStyle="{StaticResource ModernCalendarButton}"/>
                </Border>

                <TextBlock Grid.Row="2" Text="{Binding TotalPoints, StringFormat='Punkty w tym dniu: {0}'}" FontSize="16" FontWeight="Bold"
                           Foreground="{StaticResource AccentAmber}" HorizontalAlignment="Center" Margin="0,16,0,0"/>

                <StackPanel Grid.Row="3" Margin="0,20,0,0">
                    <Button Content="Pokaż nawyki i nastrój" Style="{StaticResource PrimaryButton}" Background="{StaticResource AccentGreen}"
                            Margin="0,0,0,10" Padding="15,15" FontSize="16"
                            Command="{Binding ChangeViewCommand}" CommandParameter="1"/>
                    <Button Content="Przejdź do statystyk" Style="{StaticResource PrimaryButton}" Background="{StaticResource AccentBlue}"
                            Padding="15,15" FontSize="16"
                            Command="{Binding ChangeViewCommand}" CommandParameter="2"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
