<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="MYWAY.Views.TasksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="6*"/>
            <ColumnDefinition Width="4*"/>
        </Grid.ColumnDefinitions>

        <!-- Left: To-Do List & Extra Tasks -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="3*"/>
                <RowDefinition Height="2*"/>
            </Grid.RowDefinitions>

            <!-- Regular Tasks -->
            <Border Grid.Row="0" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="{Binding SelectedDate, StringFormat='Zadania na: {0:dd.MM.yyyy}'}"
                               FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextStrong}" Margin="0,0,0,15"/>

                    <!-- Add Task Form -->
                    <Grid Grid.Row="1" Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Nazwa zadania"
                                   FontSize="12" Foreground="{StaticResource TextMuted}" Margin="0,0,0,6"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Poziom trudności"
                                   FontSize="12" Foreground="{StaticResource TextMuted}" Margin="0,0,10,6"/>

                        <TextBox Grid.Row="1" Grid.Column="0" Text="{Binding NewTaskTitle, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource InputTextBox}" Margin="0,0,10,0" ToolTip="Tytuł zadania"/>

                        <ComboBox Grid.Row="1" Grid.Column="1" SelectedIndex="{Binding NewTaskDifficulty}" Width="190" Margin="0,0,10,0"
                                  VerticalContentAlignment="Center" Style="{StaticResource AnimatedComboBox}">
                            <ComboBoxItem Content="Wybierz trudność..."/>
                            <ComboBoxItem Content="Łatwe (1)"/>
                            <ComboBoxItem Content="Średnie (2)"/>
                            <ComboBoxItem Content="Trudne (3)"/>
                        </ComboBox>

                        <Button Grid.Row="1" Grid.Column="2" Content="Dodaj" Style="{StaticResource PrimaryButton}"
                                Command="{Binding AddTaskCommand}"/>
                    </Grid>

                    <!-- Task List (Filtered) -->
                    <ListBox Grid.Row="2" ItemsSource="{Binding FilteredTasks}" BorderThickness="0" Background="Transparent"
                             HorizontalContentAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource SurfaceAlt}" BorderBrush="{StaticResource Stroke}" BorderThickness="1"
                                        CornerRadius="10" Padding="15" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsCompleted, Mode=OneWay}"
                                                  Command="{Binding DataContext.CompleteTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  CommandParameter="{Binding}" VerticalAlignment="Center" Margin="0,0,15,0">
                                            <CheckBox.LayoutTransform>
                                                <ScaleTransform ScaleX="1.4" ScaleY="1.4"/>
                                            </CheckBox.LayoutTransform>
                                        </CheckBox>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextStrong}"
                                                       TextDecorations="{Binding IsCompleted, Converter={StaticResource BooleanToTextDecorationConverter}, FallbackValue=None}" />
                                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                <Border Background="#DBEAFE" CornerRadius="6" Padding="6,2" Margin="0,0,10,0">
                                                    <TextBlock Text="{Binding DifficultyText}" FontSize="12" Foreground="#1E40AF" FontWeight="SemiBold"/>
                                                </Border>
                                                <Border Background="#FEE2E2" CornerRadius="6" Padding="6,2"
                                                        Visibility="{Binding IsOverdue, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Text="Zaległe" FontSize="12" Foreground="#991B1B" FontWeight="Bold"/>
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>

                                        <Button Grid.Column="2" Content="Skupienie" Style="{StaticResource PrimaryButton}"
                                                Background="{StaticResource AccentGreen}" Margin="0,0,10,0"
                                                Command="{Binding DataContext.StartFocusTimerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" VerticalAlignment="Center"
                                                Visibility="{Binding IsCompleted, Converter={StaticResource InvertedBooleanToVisibilityConverter}}"/>

                                        <Button Grid.Column="3" Content="Usuń" Style="{StaticResource PrimaryButton}"
                                                Background="{StaticResource Danger}"
                                                Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Dodatkowe Zadania -->
            <Border Grid.Row="1" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Dodatkowe zadania" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextStrong}" Margin="0,0,0,10"/>

                    <StackPanel Grid.Row="1" Margin="0,0,0,10">
                        <TextBox Text="{Binding NewExtraTitle, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBox}"
                                 Margin="0,0,0,10" ToolTip="Opis np. Ciężki trening (siłownia)"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Punkty:" VerticalAlignment="Center" Margin="0,0,10,0"
                                       Foreground="{StaticResource TextMuted}" FontWeight="SemiBold"/>
                            <TextBox Grid.Column="1" Text="{Binding NewExtraPoints, UpdateSourceTrigger=PropertyChanged}" Width="70"
                                     HorizontalAlignment="Left" VerticalAlignment="Center" VerticalContentAlignment="Center"
                                     Height="34" Style="{StaticResource InputTextBox}" Padding="6,4"/>
                            <Button Grid.Column="2" Content="Dodaj aktywność" Style="{StaticResource SecondaryButton}"
                                    Command="{Binding AddExtraActivityCommand}"/>
                        </Grid>
                    </StackPanel>

                    <ListBox Grid.Row="2" ItemsSource="{Binding FilteredExtraActivities}" BorderThickness="0" Background="Transparent"
                             HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource SurfaceAlt}" BorderBrush="{StaticResource Stroke}" BorderThickness="1"
                                        CornerRadius="8" Padding="10" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextStrong}" TextWrapping="Wrap"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Points, StringFormat='+ {0} pkt'}" FontSize="14" FontWeight="Bold"
                                                   Foreground="{StaticResource AccentGreen}" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <!-- Right: Calendar & Navigation -->
        <Border Grid.Column="1" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Calendar -->
                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Wybierz dzień" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextStrong}"
                               Margin="0,0,0,10" HorizontalAlignment="Center"/>

                    <Border Grid.Row="1" Background="{StaticResource SurfaceAlt}" BorderBrush="{StaticResource Stroke}" BorderThickness="1"
                            CornerRadius="12" Padding="10" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="360">
                        <Calendar SelectedDate="{Binding SelectedDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Background="Transparent" BorderThickness="0" FontSize="15"
                                  Foreground="{StaticResource TextStrong}"
                                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch" MinHeight="320"/>
                    </Border>

                    <TextBlock Grid.Row="2" Text="{Binding TotalPoints, StringFormat='Punkty w tym dniu: {0}'}" FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource AccentAmber}" HorizontalAlignment="Center" Margin="0,16,0,0"/>
                </Grid>

                <!-- Navigation Buttons -->
                <StackPanel Grid.Row="1" VerticalAlignment="Bottom">
                    <Button Content="Pokaż nawyki i nastrój" Style="{StaticResource PrimaryButton}" Background="{StaticResource AccentGreen}"
                            Margin="0,0,0,10" Padding="15,15" FontSize="16"
                            Command="{Binding ChangeViewCommand}" CommandParameter="1"/>
                    <Button Content="Przejdź do statystyk" Style="{StaticResource PrimaryButton}" Background="{StaticResource AccentBlue}"
                            Padding="15,15" FontSize="16"
                            Command="{Binding ChangeViewCommand}" CommandParameter="2"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
